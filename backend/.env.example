# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/transport_booking

# CORS
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=your_jwt_secret_change_me_in_production

# Seat Hold TTL (minutes)
SEAT_HOLD_TTL_MINUTES=15

# SMTP Email
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=no-reply@transport-booking.com

# OTP Expiry (minutes)
OTP_EXPIRY_MINUTES=15

# VNPAY Test Config
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:5173/user/booking/vnpay-return

# PayPal Test Config
PAYPAL_CLIENTID=
PAYPAL_SECRET=
PAYPAL_BASEURL=https://api-m.sandbox.paypal.com
# Frontend origin only (no path)
PAYPAL_REDIRECT_BASE_URL=http://localhost:5173
PAYPAL_CURRENCY=USD
PAYPAL_EXCHANGE_RATE=25000
